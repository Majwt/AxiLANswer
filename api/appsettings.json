{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    // password exposed which can be a security risk, 
    // but as this is considered to only have access to a single table and readonly access, it should be fine.
    "Default": "Server=<server>;Database=<database>;User Id=<username>;Password=<Password>;TrustServerCertificate=True;" 
  },
  "Kestrel": {
    "Endpoints": {
      "http": {
        "Url": "http://<backend-fqdn>:5035" // change to your backend fqdn and port
      }
    }
  },
  "Database": {
    "table_name": "dbo.top_connections"
  },
  "AllowedHosts": "https://<frontend-fqdn>:3000" // change to your frontend fqdn and port
}
